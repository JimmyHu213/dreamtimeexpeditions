{
  "name": "dreamtime",
  "version": "0.1.0",
  "private": true,
  "description": "Dreamtime Expeditions platform — marketing site, booking, operations, AI agents",
  "packageManager": "pnpm@10.28.1",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "deploy": "turbo run deploy --filter=@dreamtime/web"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.3",
    "@commitlint/config-conventional": "^21.2.0",
    "turbo": "^2.10.2"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "sharp",
      "workerd",
      "unrs-resolver"
    ],
    "overrides": {
      "undici": "7.28.0"
    }
  }
}
