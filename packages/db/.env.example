# Copy to .env (gitignored) for drizzle-kit migrations.
# Use the Supabase DIRECT connection (port 5432) for migrations, not the pooler.
# Settings → Database → Connection string → "Direct connection".
# sslmode=no-verify encrypts the connection but skips chain verification
# (Supabase's CA isn't in the local trust store; standard for Supabase tooling).
DATABASE_URL="postgresql://postgres:<password>@db.<ref>.supabase.co:5432/postgres?sslmode=no-verify"
